# =============================================================================
# Appointment Booking System — Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in values for your local environment.
# NEVER commit .env to version control.
# =============================================================================

# --- Rails -------------------------------------------------------------------
RAILS_ENV=development
RAILS_MAX_THREADS=5
PORT=3000

# --- PostgreSQL (Primary Database) -------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password
DB_NAME_DEVELOPMENT=appointment_booking_development
DB_NAME_TEST=appointment_booking_test
DB_NAME_PRODUCTION=appointment_booking_production

# --- MongoDB (Secondary / Dual-Write) ----------------------------------------
MONGODB_URI=mongodb://user:password@localhost:27017/appointment_booking
MONGODB_URI_TEST=mongodb://user:password@localhost:27017/appointment_booking_test
